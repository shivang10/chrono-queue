                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "clamp_max(clamp_min(100 * sum by (service) (jvm_memory_used_bytes{service=~\"$service\", area=\"heap\", instance=~\"$instance\", env=~\"$env\"}) / clamp_min(sum by (service) (jvm_memory_max_bytes{service=~\"$service\", area=\"heap\", instance=~\"$instance\", env=~\"$env\"}), 1e-9), 0), 100)",
                    "legendFormat": "{{service}}",
                    "refId": "A",
                    "interval": ""
                }
            ],
            "description": "JVM heap used as a percentage of max heap per service."
