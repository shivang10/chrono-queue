    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Lettuce command completion average and max latency reported by job-worker and retry-dispatcher via Micrometer. Average above 2ms or max above 5ms indicates Redis latency is contributing to processing delays. Note: Spring Boot Lettuce metrics are summaries (count/sum/max) — true percentiles require enabling histogram buckets via management.metrics.distribution.percentiles-histogram.lettuce.command=true.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "line",
              "steps": [
                {
                  "color": "transparent",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 0.005
                }
              ]
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.002
              },
              {
                "color": "red",
                "value": 0.005
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "id": 11,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Lettuce Command Completion Latency — Avg & Max",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (application) (rate(lettuce_command_completion_seconds_sum[$__rate_interval])) / clamp_min(sum by (application) (rate(lettuce_command_completion_seconds_count[$__rate_interval])), 1e-9)",
          "legendFormat": "avg latency — {{application}}",
          "refId": "A",
          "interval": ""
        },
