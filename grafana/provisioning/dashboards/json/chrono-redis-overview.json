          "expr": "redis_connected_clients",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "description": "Number of active client connections to Redis. Each Spring Boot service (job-worker, retry-dispatcher) maintains a Lettuce connection pool. Values exceeding the configured maxclients limit will cause rejected connections."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 1
      },
      "id": 4,
