      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Resident Set Size — the amount of memory allocated by the OS for Redis. Higher than 'Memory Used' due to OS overhead.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "bytes"
