          "expr": "sum(redis_db_keys)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "description": "Total number of keys across all Redis databases. For chrono-queue this includes deduplication keys and retry metadata."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Rate of keys being evicted per second due to maxmemory policy. Any evictions indicate memory pressure.",
