            "title": "JVM Heap Used — All Services",
            "type": "timeseries",
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${datasource}"
                    },
                    "expr": "sum by (service) (jvm_memory_used_bytes{service=~\"$service\", area=\"heap\", instance=~\"$instance\", env=~\"$env\"})",
                    "legendFormat": "{{service}}",
                    "refId": "A",
                    "interval": ""
